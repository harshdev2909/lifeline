#!/usr/bin/env bash
# Repo-root convenience wrapper so the documented command works verbatim:
#   ./lifeline ask "Explain heat stroke first aid in 3 steps"
# Equivalent to: npm run lifeline -- <args>
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec node --import tsx "$DIR/packages/node-app/src/cli.ts" "$@"
