{
  "name": "lifeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Offline-first first-aid assistant: grounded medical answers on-device, with peer-to-peer model delegation.",
  "author": "Harsh Sharma <harsh.dev2909@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshdev2909/lifeline.git"
  },
  "homepage": "https://github.com/harshdev2909/lifeline#readme",
  "bugs": "https://github.com/harshdev2909/lifeline/issues",
  "keywords": [
    "offline-first",
    "on-device",
    "edge-ai",
    "peer-to-peer",
    "first-aid",
    "medical",
    "rag",
    "llm",
    "privacy",
    "qvac"
  ],
  "workspaces": [
    "packages/core",
    "packages/node-app",
    "packages/server",
    "packages/web"
  ],
  "engines": {
    "node": ">=22.17"
  },
  "scripts": {
    "sysinfo": "tsx packages/core/src/sysinfo.ts",
    "lifeline": "tsx packages/node-app/src/cli.ts",
    "ask": "tsx packages/node-app/src/cli.ts ask",
    "serve": "tsx packages/node-app/src/cli.ts serve",
    "bench": "tsx packages/node-app/src/cli.ts bench",
    "prefetch:embeddings": "node scripts/prefetch-embeddings.mjs",
    "bridge": "tsx packages/server/src/main.ts",
    "web": "npm run dev --workspace @lifeline/web",
    "ui": "node scripts/ui.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm run typecheck --workspace @lifeline/web",
    "test": "node --import tsx --test packages/core/test/*.test.ts packages/server/test/*.test.ts",
    "demo": "bash scripts/demo.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
