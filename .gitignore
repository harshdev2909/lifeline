# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# OS / editor
.DS_Store
.env
.env.*

# Model weight cache — QVAC downloads/caches GGUF/ONNX weights on first run.
# Never commit weights; they are fetched on demand and cached locally.
# .qvac-home/ is QVAC's storage root, redirected here off the (full) home disk.
.qvac/
.qvac-home/
.qvac-home-consumer/
.qvac-cache/
models/
*.gguf
*.onnx

# Evidence run logs: ignore everything EXCEPT the committed sample runs.
evidence/*.jsonl
!evidence/run-sample.jsonl
!evidence/run-sample-delegated.jsonl
!evidence/run-sample-bench.jsonl
!evidence/run-sample-fallback.jsonl
!evidence/run-sample-rag-grounded.jsonl
!evidence/run-sample-rag-refuse.jsonl
!evidence/run-sample-rag-delegated.jsonl
!evidence/run-sample-medbench.jsonl

# medbench markdown tables (keep one sample)
evidence/medbench-*.md
!evidence/medbench-sample.md
