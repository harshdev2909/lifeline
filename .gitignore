# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# OS / editor
.DS_Store
.env
.env.*

# Model weight cache — QVAC downloads/caches GGUF/ONNX weights on first run.
# Never commit weights; they are fetched on demand and cached locally.
# .qvac-home/ is QVAC's storage root, redirected here off the (full) home disk.
.qvac/
.qvac-home/
.qvac-home-consumer/
.qvac-cache/
models/
*.gguf
*.onnx

# test image binaries are tiny + synthetic — keep them
!corpus/test-images/*.bmp

# Local UI bridge settings (model/language/peers/theme), written at runtime.
.lifeline-ui.json

# Submission drafts — kept locally, not part of the public repo.
submission/
